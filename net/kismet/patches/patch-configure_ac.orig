-# fi
+printf "       HackRF spectrum: "
+if test "$BUILD_CAPTURE_HACKRF_SWEEP" -eq 1; then
+	echo "yes (libhackrf and libfftw3 present)";
+else
+	echo "no ($HACKRF_MISSING_REASON)";
+fi
 
 printf "        Built-in Debug: "
 echo $BACKTRACE_WARNING
